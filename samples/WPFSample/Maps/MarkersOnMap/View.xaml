<UserControl x:Class="WPFSample.Maps.MarkersOnMap.View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vms="clr-namespace:ViewModelsSamples.Maps.MarkersOnMap;assembly=ViewModelsSamples">
    <UserControl.DataContext>
        <vms:ViewModel/>
    </UserControl.DataContext>
    <!-- VisualElements is wired up in code-behind because the GeoMap source-gen
         doesn't currently expose it as a bindable DependencyProperty. -->
    <lvc:GeoMap
        x:Name="geoMap"
        Series="{Binding Series}"
        MapProjection="Mercator"/>
</UserControl>
