<UserControl
    x:Class="AvaloniaSample.Sankeys.Basic.View"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:vms="clr-namespace:ViewModelsSamples.Sankeys.Basic;assembly=ViewModelsSamples"
    x:DataType="vms:ViewModel">

    <UserControl.DataContext>
        <vms:ViewModel/>
    </UserControl.DataContext>

    <lvc:SankeyChart>
        <lvc:SankeyChart.Series>
            <lvc:XamlSankeySeries
                Values="{Binding Nodes}"
                Links="{Binding Links}"
                NodeWidth="14"
                NodePadding="10"
                Fill="{lvc:SolidColorPaint Color='#608ada'}"
                DataLabelsPaint="{lvc:SolidColorPaint Color='#45454d'}"
                DataLabelsSize="13"/>
        </lvc:SankeyChart.Series>
    </lvc:SankeyChart>
</UserControl>
