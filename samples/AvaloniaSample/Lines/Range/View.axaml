<UserControl
    x:Class="AvaloniaSample.Lines.Range.View"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:vms="using:ViewModelsSamples.Lines.Range"
    x:DataType="vms:ViewModel">

    <UserControl.DataContext>
        <vms:ViewModel/>
    </UserControl.DataContext>

    <lvc:CartesianChart>
        <lvc:CartesianChart.Series>
            <lvc:XamlRangeLineSeries
                Values="{Binding Temperatures}"
                SeriesName="Temperature"
                YToolTipLabelFormatter="{Binding TempTooltipFormatter}"/>
        </lvc:CartesianChart.Series>

        <lvc:CartesianChart.XAxes>
            <lvc:XamlAxis Labels="{Binding Months}"/>
        </lvc:CartesianChart.XAxes>

        <lvc:CartesianChart.YAxes>
            <lvc:XamlAxis Labeler="{Binding TempLabeler}"/>
        </lvc:CartesianChart.YAxes>
    </lvc:CartesianChart>
</UserControl>
