<UserControl x:Class="WinUISample.Maps.MarkersOnMap.View"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
            xmlns:vms="using:ViewModelsSamples.Maps.MarkersOnMap"
            mc:Ignorable="d">
    <UserControl.DataContext>
        <vms:ViewModel/>
    </UserControl.DataContext>
    <!-- VisualElements is wired up in code-behind because the GeoMap source-gen
         doesn't currently expose it as a bindable property. -->
    <lvc:GeoMap
        x:Name="geoMap"
        Series="{Binding Series}"
        MapProjection="Mercator"/>
</UserControl>
